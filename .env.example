# ===============================================
# AZACH E-Commerce Environment Variables
# ===============================================
#
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control!
#

# ===============================================
# SUPABASE CONFIGURATION
# ===============================================
# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous (public) key - safe to use in frontend
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role key - KEEP SECRET! Only for Edge Functions
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ===============================================
# PAYMENT PROVIDER CONFIGURATION
# ===============================================

# Choose payment provider: "stripe" or "paystack"
VITE_PAYMENT_PROVIDER=paystack

# --- Stripe Configuration (if using Stripe) ---
# Stripe publishable key (test: pk_test_..., live: pk_live_...)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key

# Stripe secret key (test: sk_test_..., live: sk_live_...)
# IMPORTANT: Only use in Edge Functions, never in frontend
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Stripe webhook secret for signature verification
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# --- Paystack Configuration (for Nigerian market) ---
# Paystack public key (test: pk_test_..., live: pk_live_...)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# Paystack secret key (test: sk_test_..., live: sk_live_...)
# IMPORTANT: Only use in Edge Functions, never in frontend
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key

# ===============================================
# DHL EXPRESS SHIPPING CONFIGURATION
# ===============================================

# DHL Express API Key (from DHL Developer Portal)
DHL_API_KEY=your_dhl_api_key

# DHL Express API Secret
DHL_API_SECRET=your_dhl_api_secret

# DHL Account Number (your DHL Express shipper account)
DHL_ACCOUNT_NUMBER=your_dhl_account_number

# Origin location for shipments (Nigeria)
DHL_ORIGIN_POSTAL_CODE=100001
DHL_ORIGIN_CITY=Lagos
DHL_ORIGIN_COUNTRY=NG

# ===============================================
# CURRENCY CONFIGURATION
# ===============================================

# Base currency for pricing (NGN for Nigerian market)
# All prices in database are stored in this currency
VITE_BASE_CURRENCY=NGN

# ===============================================
# APPLICATION SETTINGS
# ===============================================

# Application URL (for Paystack callbacks and email links)
VITE_APP_URL=http://localhost:5173

# Environment (development, staging, production)
VITE_ENVIRONMENT=development

# ===============================================
# OPTIONAL: EMAIL CONFIGURATION
# ===============================================

# If you want to send transactional emails (order confirmations, etc.)
# Configure your email service provider here
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASS=your_email_password
# SMTP_FROM=noreply@azach.com

# ===============================================
# OPTIONAL: ANALYTICS
# ===============================================

# Google Analytics tracking ID
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# ===============================================
# SETUP INSTRUCTIONS
# ===============================================
#
# 1. Supabase Setup:
#    - Create project at https://supabase.com
#    - Get URL and keys from Settings > API
#    - Run migrations: supabase db push
#
# 2. Paystack Setup:
#    - Create account at https://paystack.com
#    - Get API keys from Settings > API Keys & Webhooks
#    - Set webhook URL: https://your-project.supabase.co/functions/v1/paystack-webhook
#    - Subscribe to: charge.success event
#
# 3. DHL Express Setup:
#    - Register at https://developer.dhl.com
#    - Create app and get credentials
#    - Get DHL Express account number from your account manager
#    - Set origin location to your primary shipping location
#
# 4. Testing:
#    - Use test API keys for development
#    - Paystack test cards: https://paystack.com/docs/payments/test-payments
#    - DHL has sandbox environment for testing
#
# 5. Production:
#    - Replace all test keys with live keys
#    - Set VITE_ENVIRONMENT=production
#    - Update VITE_APP_URL to your production domain
#    - Enable 2FA on all service accounts
#
# ===============================================
